generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  password     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  profiles     Profile[]
  watchlist    Watchlist[]
  watchHistory WatchHistory[]
}

model Profile {
  id        Int      @id @default(autoincrement())
  name      String
  avatarUrl String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Genre {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  contents Content[]
}

model Content {
  id           Int            @id @default(autoincrement())
  title        String
  description  String
  genreId      Int
  genre        Genre          @relation(fields: [genreId], references: [id])
  releaseYear  Int
  director     String
  actors       String
  thumbnailUrl String
  videoUrl     String
  duration     Int
  type         String         // "MOVIE" | "SERIES"
  rating       Float
  createdAt    DateTime       @default(now())
  watchlist    Watchlist[]
  watchHistory WatchHistory[]
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  contentId Int
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model WatchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  contentId Int
  watchedAt DateTime @default(now())
  progress  Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}
